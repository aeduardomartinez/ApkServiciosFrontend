# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out
/www
/build
/.angular
/.angular/cache

# Dependency directories
/node_modules

# Ionic/Capacitor
/.ionic
/platforms
/plugins
/android/app/build
/ios/App/build
/ios/App/Pods

# Environment variables & Secrets
.env
.env.*
*.jks
*.keystore
*.p12
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
log.txt
build_output*.txt

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# System files
.DS_Store
Thumbs.db
$RECYCLE.BIN/

# Temporary files
*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*

# Testing
/coverage
testem.log

# Miscellaneous
/.nx
/.nx/cache
/connect.lock
/libpeerconnection.log
/typings
